{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:gluendo:schema:{{domain}}:{{entity}}:v1.0.0",
  "title": "{{Entity Name}}",
  "description": "Canonical representation of a {{entity}} entity. Describe when and by whom this entity is produced.",
  "type": "object",
  "required": ["{{entity}}Id"],
  "properties": {
    "{{entity}}Id": {
      "type": "string",
      "description": "Unique identifier for the {{entity}}"
    },
    "status": {
      "oneOf": [
        { "const": "active", "description": "Currently active" },
        { "const": "inactive", "description": "No longer active" }
      ],
      "description": "Current {{entity}} status"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the {{entity}} was created (ISO 8601)"
    },
    "address": {
      "$ref": "../../../_common/types/address.schema.json",
      "description": "Associated address"
    }
  }
}
